NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ISSUER=edutask
JWT_AUDIENCE=edutask-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=edutask
# Runtime DB URL should point to Supabase pooler in staging/prod.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# Direct DB URL is for migrations only (never app runtime).
SUPABASE_DB_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Pooler URL is for backend runtime traffic.
SUPABASE_DB_POOLER_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# Backend-only secret (never expose to frontend or client bundle).
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# Frontend-safe public key (read-only client use).
SUPABASE_ANON_KEY=replace-with-anon-key
DB_SSL=true

ENABLE_AUTOMATION=true
AUTOMATION_DRY_RUN=false
ENABLE_RATE_LIMITS=true
ENABLE_IDEMPOTENCY=true
JSON_BODY_LIMIT=256kb
URLENCODED_BODY_LIMIT=256kb
SLOW_QUERY_LOG_MS=200
PGPOOL_MAX=20
SERIALIZABLE_TXN_WARN_MS=1500
LOAD_MEMORY_LOG_INTERVAL_MS=5000
REDIS_URL=redis://localhost:6379
PLATFORM_FEE_PERCENTAGE=10
REFERRAL_REWARD_AMOUNT=5
