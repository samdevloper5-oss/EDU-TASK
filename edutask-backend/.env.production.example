NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=https://app.edutask.example
JWT_SECRET=replace-with-prod-jwt-secret
JWT_REFRESH_SECRET=replace-with-prod-refresh-secret
JWT_ISSUER=edutask
JWT_AUDIENCE=edutask-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_POOLER_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
DB_SSL=true

ENABLE_AUTOMATION=true
AUTOMATION_DRY_RUN=false
ENABLE_RATE_LIMITS=true
ENABLE_IDEMPOTENCY=true
JSON_BODY_LIMIT=256kb
URLENCODED_BODY_LIMIT=256kb
SLOW_QUERY_LOG_MS=200
PGPOOL_MAX=30
SERIALIZABLE_TXN_WARN_MS=1200
LOAD_MEMORY_LOG_INTERVAL_MS=5000
REDIS_URL=redis://redis:6379
PLATFORM_FEE_PERCENTAGE=10
REFERRAL_REWARD_AMOUNT=5
